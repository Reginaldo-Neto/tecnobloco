# =============================================
# TECNOBLOCO ERP — Variáveis de Ambiente
# Copie para backend/.env e preencha os valores
# =============================================

# Servidor
PORT=3001
NODE_ENV=production

# Banco de Dados (preencher com dados do Railway/TiDB/etc)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=sua_senha_aqui
DB_NAME=tecnobloco
DB_CONNECTION_LIMIT=10

# JWT — gere uma chave segura: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque_por_uma_chave_segura_de_pelo_menos_64_caracteres
JWT_EXPIRES_IN=8h

# Segurança
BCRYPT_ROUNDS=10
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=500
AUTH_RATE_LIMIT_MAX=20

# Logs
LOG_LEVEL=info
LOG_DIR=logs

# CORS — domínio(s) do frontend em produção (separe por vírgula se houver mais de um)
# Deixe vazio para permitir qualquer origem (não recomendado em produção)
# ALLOWED_ORIGINS=https://seu-app.railway.app
