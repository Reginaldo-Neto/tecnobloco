# =============================================
# TECNOBLOCO ERP — Variáveis de Ambiente
# Copie este arquivo para backend/.env e preencha
# =============================================

# Servidor
PORT=3001
NODE_ENV=development

# Banco de Dados
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=1234
DB_NAME=tecnobloco
DB_CONNECTION_LIMIT=10

# JWT
JWT_SECRET=troque_por_uma_chave_segura_de_pelo_menos_64_caracteres
JWT_EXPIRES_IN=8h

# Segurança
BCRYPT_ROUNDS=10
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Logs
LOG_LEVEL=info
LOG_DIR=logs
